# =============================================================================
#  AutoAllocator — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# =============================================================================

# OpenAI
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ERC-8004 / Web3
# Get a free Base Sepolia RPC URL at: https://alchemy.com (App > Networks > Base Sepolia)
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Wallet private key used by scripts/register_agents.py (one-time setup only)
# Fund it with Sepolia ETH from: https://www.alchemy.com/faucets/base-sepolia
DEPLOYER_PRIVATE_KEY=0x...

# Coinbase CDP SDK (for on-chain USDC transfers via execute_node)
# Create a CDP API key at: https://portal.cdp.coinbase.com/access/api
# Choose "Secret API Key" type (NOT Smart Wallet)
CDP_API_KEY_ID=your-api-key-id
CDP_API_KEY_SECRET=your-api-key-secret

# CDP Wallet Secret — needed for signing transactions (set in CDP dashboard)
CDP_WALLET_SECRET=your-wallet-secret

# Network
NETWORK_ID=base-sepolia

# App
APP_ENV=development
APP_VERSION=0.1.0
