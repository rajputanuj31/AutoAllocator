# =============================================================================
#  AutoAllocator — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# =============================================================================

# OpenAI
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ERC-8004 / Web3
# Get a free Base Sepolia RPC URL at: https://alchemy.com (App > Networks > Base Sepolia)
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Network
NETWORK_ID=base-sepolia

# Auth — JWT secret for signing API tokens (change this in production!)
JWT_SECRET=your-very-secret-key-change-in-production

# App
APP_ENV=development
APP_VERSION=0.1.0
